export MalterlibScriptPath="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
export MalterlibBashSourceFull="$DIR/${BASH_SOURCE[0]##*/}"

set -eo pipefail

cd "$MalterlibScriptPath"

if [ -e .malterlib_only_repos ] && [[ "$MalterlibOnlyRepositoryManagement" == "" ]]; then
	export MalterlibOnlyRepositoryManagement=true
fi

if [ -e Binaries/Malterlib/LICENSE.Malterlib ]; then
	rm -rf Binaries/Malterlib
fi

if [ -e Malterlib/Core ]; then
	find "$MalterlibScriptPath/Malterlib/Core" -maxdepth 0 -type d -empty -exec rmdir {} \;
fi

function OutputInfo()
{
	if [[ "$TERM" == "dumb" ]]; then
		echo $'\e[1m\e[36m'"$@"$'\e[0m'
	else
		echo $'\e[38;5;39m'"$@"$'\e[0m'
	fi
}

function OutputNote()
{
	if [[ "$TERM" == "dumb" ]]; then
		echo $'\e[1m\e[33m'"$@"$'\e[0m'
	else
		echo $'\e[38;5;221m'"$@"$'\e[0m'
	fi
}

function OutputHeading()
{
	if [[ "$TERM" == "dumb" ]]; then
		echo $'\e[1m\e[32m'"$@"$'\e[0m'
	else
		echo $'\e[38;5;118m'"$@"$'\e[0m'
	fi
}

function OutputError()
{
	if [[ "$TERM" == "dumb" ]]; then
		echo $'\e[1m\e[31m'"$@"$'\e[0m'
	else
		echo $'\e[38;5;198m'"$@"$'\e[0m'
	fi
}

BootstrapInit=false
function BootstrapInit()
{
	if $BootstrapInit; then
		return
	fi

	BootstrapInit=true

	echo
	OutputHeading '╭─────────────────────────╮'
	OutputHeading '│ Bootstrapping Malterlib │'
	OutputHeading '╰─────────────────────────╯'
	echo

	# Make sure that lfs is installed
	if ! git lfs > /dev/null ; then
		echo Please install git lfs
		exit 1
	fi

	if ! cat ~/.gitconfig | grep 'filter "lfs"' > /dev/null ; then
		git lfs install
	fi

	if [[ "$MalterlibPlatform" ==  Windows ]]; then
		git config --global core.symlinks true
	fi
}

function ReportBootstrapDone()
{
	if ! $BootstrapInit; then
		return
	fi

	OutputHeading '╭─────────────────────────────────────╮'
	OutputHeading '│ Successfully bootstrapped Malterlib │'
	OutputHeading '╰─────────────────────────────────────╯'
	echo
}

function IsWorktree()
{
	if [ -f "$MalterlibScriptPath/.git" ]; then
		local GitDirContent
		GitDirContent=$(cat "$MalterlibScriptPath/.git")
		if [[ "$GitDirContent" == gitdir:*/.git/worktrees/* ]]; then
			return 0
		fi
	fi
	return 1
}

function GetWorktreeMainRoot()
{
	if [ -f "$MalterlibScriptPath/.git" ]; then
		local GitDir
		GitDir=$(cat "$MalterlibScriptPath/.git" | sed 's/^gitdir: //')
		# Resolve relative path
		GitDir=$(cd "$MalterlibScriptPath" && cd "$GitDir" && pwd)
		# Read commondir to find main .git
		if [ -f "$GitDir/commondir" ]; then
			local CommonDir
			CommonDir=$(cat "$GitDir/commondir")
			local MainGitDir
			MainGitDir=$(cd "$GitDir" && cd "$CommonDir" && pwd)
			# Main root is parent of .git directory
			echo "$(dirname "$MainGitDir")"
		else
			# Fallback: parse path - gitdir is <main>/.git/worktrees/<name>
			echo "$GitDir" | sed 's|/\.git/worktrees/.*$||'
		fi
	fi
}

function DetectRepoRoot()
{
	if [[ "$MalterlibRepoRoot" == "" ]]; then

		OutputInfo "Determine MalterlibRepoRoot from *.MBuildSystem:"

		MalterlibRepoRoot=https://github.com/Malterlib
		BuildSystemContents=`cat *.MBuildSystem | grep MalterlibRepoRoot || true`

		ToMatch='[ \t]*MalterlibRepoRoot[ \t]+(.*)'
		while [[ $BuildSystemContents =~ $ToMatch ]]; do
			BuildSystemContents=${BASH_REMATCH[1]}
			break
		done

		ToMatch='^"(.*)"$'
		while [[ $BuildSystemContents =~ $ToMatch ]]; do
			BuildSystemContents=${BASH_REMATCH[1]}
			break
		done
		if [[ "$BuildSystemContents" != "" ]]; then
			MalterlibRepoRoot="$BuildSystemContents"
			echo "Found customized MalterlibRepoRoot: `OutputNote "$MalterlibRepoRoot"`"
		else
			echo "Using default MalterlibRepoRoot: `OutputNote "$MalterlibRepoRoot"`"
		fi

		echo
	fi
}

function GetMalterlibCoreHash()
{
	cat *.MRepo | grep -A2 '"Malterlib/Core"' | grep '"Hash":' | cut '-d ' -f 2 | tr -d '"' || true
}

MalterlibChangingBootstrapVersion="false"
BootstrapVersion="5"
MalterlibCoreBootstrapVersion="2"

function DownloadPrivateGithubAsset
{
	GitHubApiToken=`printf "protocol=https\nhost=github.com\n" | git credential fill | grep password | cut -d = -f 2`

	ApiRepoRoot="https://api.github.com/repos/Malterlib/$1"
	AuthString="Authorization: token $GitHubApiToken"

	echo "    $ApiRepoRoot"
	curl -o /dev/null -sH "$AuthString" "$ApiRepoRoot" || { echo "Error: Invalid repo, token or network issue!";  exit 1; }

	echo "    $ApiRepoRoot/releases/tags/$2"
	TagResponse=$(curl -sH "$AuthString" "$ApiRepoRoot/releases/tags/$2")
	eval $(echo "$TagResponse" | grep -C3 "name.:.\+$3" | grep -w id | tr : = | tr -cd '[[:alnum:]]=')

	[ "$id" ] || { echo "Error: Failed to get asset id, response: $TagResponse" | awk 'length($0)<50' >&2; exit 1; }

	echo "    $ApiRepoRoot/releases/assets/$id"
	curl -LJo "$4" --no-progress-meter -H "Authorization: token $GitHubApiToken" -H 'Accept: application/octet-stream' "$ApiRepoRoot/releases/assets/$id"
}

function BootstrapCore()
{
	if ! [ -e Malterlib/Core ]; then
		DetectRepoRoot

		if ! [ -e Malterlib/Core ]; then

			GitHash=`GetMalterlibCoreHash`

			if IsWorktree; then
				MainRoot=$(GetWorktreeMainRoot)
				MainSubRepo="$MainRoot/Malterlib/Core"

				if [ -e "$MainSubRepo/.git" ]; then
					# Get the branch name from the current worktree, not the main
					MainBranch=$(git -C "$MalterlibScriptPath" branch --show-current)

					OutputInfo "Adding Malterlib/Core as worktree from main working tree"

					git -C "$MainSubRepo" worktree prune

					if [[ "$GitHash" != "" ]]; then
						echo "Found commit hash in *.MRepo files: `OutputNote "$GitHash"`"
						if [[ "$MainBranch" != "" ]]; then
							git -C "$MainSubRepo" worktree add -B "$MainBranch" "$MalterlibScriptPath/Malterlib/Core" "$GitHash"
						else
							git -C "$MainSubRepo" worktree add "$MalterlibScriptPath/Malterlib/Core" "$GitHash"
						fi
					else
						OutputError "Could not find commit hash in *.MRepo files using latest default branch"
						if [[ "$MainBranch" != "" ]]; then
							git -C "$MainSubRepo" worktree add -B "$MainBranch" "$MalterlibScriptPath/Malterlib/Core"
						else
							git -C "$MainSubRepo" worktree add "$MalterlibScriptPath/Malterlib/Core"
						fi
					fi
				else
					OutputInfo "Cloning Malterlib/Core"

					if [[ "$GitHash" != "" ]]; then
						echo "Found commit hash in *.MRepo files: `OutputNote "$GitHash"`"

						git clone -n "$MalterlibRepoRoot/Malterlib_Core.git" Malterlib/Core
						pushd Malterlib/Core > /dev/null
						git checkout -B master $GitHash
						popd > /dev/null
					else
						OutputError "Could not find commit hash in *.MRepo files using latest default branch"

						git clone "$MalterlibRepoRoot/Malterlib_Core.git" Malterlib/Core
					fi
				fi
			else
				OutputInfo "Cloning Malterlib/Core"

				if [[ "$GitHash" != "" ]]; then
					echo "Found commit hash in *.MRepo files: `OutputNote "$GitHash"`"

					git clone -n "$MalterlibRepoRoot/Malterlib_Core.git" Malterlib/Core
					pushd Malterlib/Core > /dev/null
					git checkout -B master $GitHash
					popd > /dev/null
				else
					OutputError "Could not find commit hash in *.MRepo files using latest default branch"

					git clone "$MalterlibRepoRoot/Malterlib_Core.git" Malterlib/Core
				fi
			fi

			echo
		fi
	fi

	MalterlibCoreBootstrapVersion="2"

	if [ -e "Malterlib/Core/Bootstrap.version" ]; then
		MalterlibCoreBootstrapVersion=`cat "Malterlib/Core/Bootstrap.version"`
	fi

	if ! [ -e ./Malterlib/Core/Scripts/Detect.sh ] || [[ "$MalterlibCoreBootstrapVersion" != "$BootstrapVersion" ]]; then
		# Upgrade path
		export MalterlibChangingBootstrapVersion=true

		git -C Malterlib/Core fetch --all --tags

		GitHash=`GetMalterlibCoreHash`
		if [[ "$GitHash" == "" ]]; then
			OutputError "Could not find commit hash in *.MRepo, cannot upgrade"
			exit 1
		fi

		if [[ "$MalterlibRepositoryHardReset" == "true" ]] || (git -C Malterlib/Core branch -r --contains HEAD > /dev/null && [ -z "$(git -C Malterlib/Core status --porcelain || echo no)" ]); then
			git -C Malterlib/Core checkout -B master $GitHash
		else
			OutputError "Malterlib/Core is not clean, please resolve the situation before trying to upgrade"
			exit 1
		fi
	fi

	unset MalterlibBinariesDir
	source ./Malterlib/Core/Scripts/Detect.sh
	if [[ "$MalterlibPlatform" ==  Windows ]]; then
		mkdir -p /tmp
	fi

	MalterlibBinariesPath="Binaries/Malterlib/${MalterlibPlatform}/${MalterlibArch}"

	if [ -e "$MalterlibScriptPath/$MalterlibBinariesPath" ]; then
		find "$MalterlibScriptPath/$MalterlibBinariesPath" -maxdepth 0 -type d -empty -exec rmdir {} \;
	fi

	export MalterlibBootstrapBinariesPath="$HOME/.Malterlib/bootstrap/$BootstrapVersion"
	if ! [ -e "$MalterlibBootstrapBinariesPath/Bootstrap.version" ]; then
		if ! "$MalterlibExecutable" install-binaries &> /dev/null; then
			BootstrapInit
			DetectRepoRoot
			export TempDir=`mktemp -d`
			mkdir -p "$TempDir"

			MalterlibBinariesRepo="MalterlibBinaries_${MalterlibPlatform}_${MalterlibArch}_rLFS"

			PublicAssetUrl="$MalterlibRepoRoot/$MalterlibBinariesRepo/releases/download/bootstrap%2F${BootstrapVersion}/MTool.tar.gz"
			echo "Trying public download"
			echo "    $PublicAssetUrl"
			ExpectedError="The requested URL returned error: 404"
			if ! curl -L --no-progress-meter -fo "$TempDir/MTool.tar.gz" "$PublicAssetUrl" 2>&1 | grep -v "$ExpectedError"; then
				echo Trying private download instead
				DownloadPrivateGithubAsset "$MalterlibBinariesRepo" "bootstrap/${BootstrapVersion}" "MTool.tar.gz" "$TempDir/MTool.tar.gz"
				echo
			fi

			mkdir -p "$MalterlibBootstrapBinariesPath"
			pushd "$MalterlibBootstrapBinariesPath" > /dev/null
				echo "$PWD:"
				if [[ "$MalterlibPlatform" ==  "macOS" ]]; then
					tar -xvf "$TempDir/MTool.tar.gz"
				else
					tar --force-local -xvf "$TempDir/MTool.tar.gz"
				fi
				./mib install-binaries
			popd > /dev/null

			echo

			ReportBootstrapDone
		fi
	fi

	if ! [ -e "$MalterlibScriptPath/$MalterlibBinariesPath/Bootstrap.version" ] || [[ `cat "$MalterlibScriptPath/$MalterlibBinariesPath/Bootstrap.version"` != "$BootstrapVersion" ]]; then
		export MalterlibChangingBootstrapVersion=true
	fi

	if [[ "$MalterlibChangingBootstrapVersion" == "true" ]]; then
		export Malterlib_UseCachedEnvironment=false
		if [ -e "BuildSystem/Default/RepositoryState.json" ]; then
			while read a; do
			    echo ${a//\"\"\: 1\,/}
			done < BuildSystem/Default/RepositoryState.json > BuildSystem/Default/RepositoryState.json.new
			mv BuildSystem/Default/RepositoryState.json{.new,}
		fi
	fi
}

BootstrapCore

export MalterlibBinariesPath

ScriptsDir="$PWD/Malterlib/Core/Scripts"
NumArguments=$#
if (( $NumArguments >= 1 )); then
	Command=$1
	shift
fi

RetriedBootstrap="false"

while true; do

	function UpdateMTool()
	{
		unset MalterlibBinariesDir
		if [[ "$PWD" != "$MalterlibScriptPath" ]]; then
			echo "Current directory is incorrect: \"$PWD\" != \"$MalterlibScriptPath\""
			exit 1
		fi

		MalterlibBinariesPath="Binaries/Malterlib/${MalterlibPlatform}/${MalterlibArch}"

		if [[ "${MalterlibUseGlobalBinaries-}" == "true" ]]; then
			MalterlibBinariesPath="$MalterlibBootstrapBinariesPath"
			export MalterlibBinariesDir="$MalterlibBinariesPath"
			source "$MalterlibScriptPath/Malterlib/Core/Scripts/Detect.sh"
		elif ! [ -e "$MalterlibScriptPath/$MalterlibBinariesPath/Bootstrap.version" ] || [[ `cat "$MalterlibScriptPath/$MalterlibBinariesPath/Bootstrap.version"` != "$BootstrapVersion" ]]; then
			MalterlibBinariesPath="$MalterlibBootstrapBinariesPath"
			export MalterlibBinariesDir="$MalterlibBinariesPath"
			source "$MalterlibScriptPath/Malterlib/Core/Scripts/Detect.sh"
		elif [[ "$1" != "false" ]]; then
			source "$MalterlibScriptPath/Malterlib/Core/Scripts/Detect.sh"
		fi

		if [[ "$MalterlibPlatform" ==  Windows ]] || [[ "$MalterlibSafeMib" == "true" ]]; then
			DependencyFile=BuildSystem/SafeMib/SafeMib.MalterlibDependency

			if [ -e "$DependencyFile" ]; then
				"$MToolExecutable" CheckDependencies Verbose=true "Directory=BuildSystem/SafeMib"
			fi

			if ! [ -e BuildSystem/SafeMib/SafeMib.updated ]; then
				echo Updating safe binaries

				ExcludePatterns="*/.git;*/.DS_Store;*.TMP"

				MalterlibDiffCopyExcludePatterns="$ExcludePatterns" "$MToolExecutable" DiffCopy "`MalterlibConvertPath \"$MalterlibBinariesPath\"`/*" "BuildSystem/SafeMib/Binaries" "" 1 1
				MalterlibDiffCopyExcludePatterns="$ExcludePatterns" "$MToolExecutable" DiffCopy "Malterlib/Core/Scripts/*" "BuildSystem/SafeMib/Scripts" "" 1 1
				"$MToolExecutable" TouchOrCreate "BuildSystem/SafeMib/SafeMib.updated"

				if type MalterlibConvertPath > /dev/null; then
					"$MToolExecutable" BuildDependencies "OutputFile=`MalterlibConvertPath \"$MalterlibScriptPath/$DependencyFile\"`" \
					"Output:`MalterlibConvertPath \"$MalterlibScriptPath/BuildSystem/SafeMib/SafeMib.updated\"`" \
					"Input:`MalterlibConvertPath \"$MalterlibBashSourceFull\"`" \
					"Find:`MalterlibConvertPath \"$MalterlibBinariesPath\"`/*;RIF;33;$ExcludePatterns" \
					"Find:`MalterlibConvertPath \"$MalterlibScriptPath/Malterlib/Core/Scripts\"`/*;RIF;33;$ExcludePatterns"
				else
					rm -f BuildSystem/SafeMib/SafeMib.updated
				fi
			fi

			export MalterlibBinariesDir="$PWD/BuildSystem/SafeMib/Binaries"
			ScriptsDir="$PWD/BuildSystem/SafeMib/Scripts"
			source ./Malterlib/Core/Scripts/Detect.sh
		fi
	}

	UpdateMTool false

	export -f UpdateMTool

	function RunTests()
	{
		Start=$SECONDS

		function OutputTime()
		{
			OutputNote "$((SECONDS-Start)) s"
			Start=$SECONDS
			echo
		}

		OutputInfo '[Building]'
		./mib build Tests
		OutputTime

		source BuildSystem/SharedBuildSettings.sh

		OutputInfo '[Testing]'

		if "$MalterlibDeployRoot/Tests/RunAllTests" "$@"; then
			OutputTime
			OutputHeading Success
		else
			OutputTime
			OutputError "Tests FAILED"
			exit 1
		fi
	}

	case "$Command" in
		generate)
			MissingSetup=false
			if [[ "$MalterlibPlatform" == macOS ]] ; then
				if [ -e ./Malterlib/Core/Setup/macOS/setup.sh ]; then
					./Malterlib/Core/Setup/macOS/setup.sh CheckSetup
				else
					MissingSetup=true
				fi
			fi

			set +e

			BootstrapVersion="$BootstrapVersion" "$ScriptsDir/mib.sh" generate "$@"

			MToolExit=$?
			set -e

			if [[ "$MalterlibChangingBootstrapVersion" == "true" ]] && [[ "$RetriedBootstrap" == "false" ]]; then
				if [[ $MToolExit > 0 ]]; then
					RetriedBootstrap="true"
					echo MTool potentially updated, running bootstrap again
					BootstrapCore
					continue
				fi
			fi

			if [[ $MToolExit != 2 ]]; then
				exit $MToolExit
			fi

			if $MissingSetup && [[ "$MalterlibPlatform" == macOS ]] && [ -e ./Malterlib/Core/Setup/macOS/setup.sh ]; then
				./Malterlib/Core/Setup/macOS/setup.sh CheckSetup
			fi
		;;
		setup_only)
			# TODO: deprecate this
			exit 0
		;;
		bootstrap-only)
			exit 0
		;;
		bootstrap_only)
			exit 0
		;;
		setup)
			if [[ "$MalterlibPlatform" == macOS ]] ; then
				./Malterlib/Core/Setup/macOS/setup.sh "$@"
			fi
		;;
		build)
			./Malterlib/Core/BuildScripts/BuildWorkspace.sh "$@"
		;;
		test)
			RunTests "$@"
		;;
		build-target)
			./Malterlib/Core/BuildScripts/BuildTarget.sh "$@"
		;;
		build_target)
			./Malterlib/Core/BuildScripts/BuildTarget.sh "$@"
		;;
		prebuild)
			./Malterlib/Core/BuildScripts/Prebuild.sh "$@"
		;;
		postbuild)
			./Malterlib/Core/BuildScripts/Postbuild.sh "$@"
		;;
		detect-system)
			source ./Malterlib/Core/BuildScripts/DetectSystem.sh "$@"
		;;
		detect_system)
			source ./Malterlib/Core/BuildScripts/DetectSystem.sh "$@"
		;;
		*)
			set +e
			if (( $NumArguments >= 1 )); then
				BootstrapVersion="$BootstrapVersion" "$ScriptsDir/mib.sh" "$Command" "$@"
			else
				BootstrapVersion="$BootstrapVersion" "$ScriptsDir/mib.sh" "$@"
			fi
			MToolExit=$?
			set -e

			if [[ "$MalterlibChangingBootstrapVersion" == "true" ]] && [[ "$RetriedBootstrap" == "false" ]]; then
				if [[ $MToolExit > 0 ]]; then
					RetriedBootstrap="true"
					echo MTool potentially updated, running bootstrap again
					BootstrapCore
					continue
				fi
			fi

			exit $MToolExit
	esac

	break

done
