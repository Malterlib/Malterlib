Import "Malterlib/Core/Malterlib.MHeader"

Property
{
	ProductCompanyUniqueIdentifier "org.malterlib"
	ProductCompany "Malterlib"
	{
		!!ProductCompany undefined
	}

	MalterlibMainMalterlibRepo true

	MalterlibEnableInternalTests true
	{
		!!MalterlibEnableInternalTests undefined
	}

	MalterlibEnableInternalWorkspaces true
	{
		!!MalterlibEnableInternalWorkspaces undefined
	}

	MalterlibTestsMem_EnablePerfTests true

	MalterlibMemoryManager_CheckOverrideMemoryLeaks true
	{
		!!MalterlibMemoryManager_CheckOverrideMemoryLeaks undefined
	}

	MalterlibThread_LinuxUseStaticThreadLocal true
	{
		!!MalterlibThread_LinuxUseStaticThreadLocal undefined
	}

	Malterlib_AssumeMalterlibHost true
	{
		!!Malterlib_AssumeMalterlibHost undefined
	}

	MalterlibEnableOptionalModules true

	MalterlibEnableThirdPartyComparisonTests true
	{
		!!MalterlibEnableThirdPartyComparisonTests undefined
	}

	MalterlibVerboseCMakeHash: bool = false
}

Import.CMake_VerboseHash true
{
	!!MalterlibVerboseCMakeHash true
}

Repository
{
	!!Repository.Type "Root"

	License MalterlibRepoDefaultLicenseConfig
	{
		!!Repository.License undefined
	}

	CheckLicense true
	{
		!!Repository.CheckLicense undefined
	}

	License #<CommentStyles> =+ {
		Path: ["count-lines"]
		, LinePrefix: "# "
		, DetectShebang: true
	}

	License #<CommentStyles> =+ {
		Path: ["mib"]
		, LinePrefix: "# "
		, DetectShebang: true
	}

	MalterlibRepoReusePaths =+ [
		".claude/*.json"
		, ".vscode/*.json"
		, ".ignore"
		, ".rgignore"
		, "Malterlib.sublime-project"
	]
}

Repository
{
	AdditionalConfigFiles =+ ".github/repository-cache/MalterlibBinaries-Linux-arm64.MRepo"->MakeAbsolute()
	{
		!!Repository.Location "Binaries/Malterlib/Linux/arm64"->MakeAbsolute()
	}
	AdditionalConfigFiles =+ ".github/repository-cache/MalterlibBinaries-Linux-x64.MRepo"->MakeAbsolute()
	{
		!!Repository.Location "Binaries/Malterlib/Linux/x64"->MakeAbsolute()
	}
	AdditionalConfigFiles =+ ".github/repository-cache/MalterlibBinaries-Windows-arm64.MRepo"->MakeAbsolute()
	{
		!!Repository.Location "Binaries/Malterlib/Windows/arm64"->MakeAbsolute()
	}
	AdditionalConfigFiles =+ ".github/repository-cache/MalterlibBinaries-Windows-x64.MRepo"->MakeAbsolute()
	{
		!!Repository.Location "Binaries/Malterlib/Windows/x64"->MakeAbsolute()
	}
	AdditionalConfigFiles =+ ".github/repository-cache/MalterlibBinaries-macOS-arm64.MRepo"->MakeAbsolute()
	{
		!!Repository.Location "Binaries/Malterlib/macOS/arm64"->MakeAbsolute()
	}
	AdditionalConfigFiles =+ ".github/repository-cache/MalterlibBinaries-macOS-x64.MRepo"->MakeAbsolute()
	{
		!!Repository.Location "Binaries/Malterlib/macOS/x64"->MakeAbsolute()
	}
	AdditionalConfigFiles =+ ".github/repository-cache/MalterlibBinariesSDK-Linux-Ubuntu-arm64.MRepo"->MakeAbsolute()
	{
		!!Repository.Location "Binaries/MalterlibSDK/Linux/Ubuntu/arm64"->MakeAbsolute()
	}
	AdditionalConfigFiles =+ ".github/repository-cache/MalterlibBinariesSDK-Linux-Ubuntu-x64.MRepo"->MakeAbsolute()
	{
		!!Repository.Location "Binaries/MalterlibSDK/Linux/Ubuntu/x64"->MakeAbsolute()
	}

	AdditionalConfigFiles =+ ".github/repository-cache/External-llvm-project.MRepo"->MakeAbsolute()
	{
		!!Repository.Location "External/llvm-project"->MakeAbsolute()
	}
}
