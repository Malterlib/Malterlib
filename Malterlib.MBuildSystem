Property
{
	ProductCompanyUniqueIdentifier "org.malterlib"
	ProductCompany "Malterlib"
	{
		!!ProductCompany ""
	}
	
	MalterlibMainMalterlibRepo true

	MalterlibEnableInternalTests true
	{
		!!MalterlibEnableInternalTests ""
	}

	MalterlibEnableInternalWorkspaces true
	{
		!!MalterlibEnableInternalWorkspaces ""
	}

	MalterlibTestsMem_EnablePerfTests true // User(Tests)=false: Enable performance memory tests (default true)
	{
		!!MalterlibTestsMem_EnablePerfTests ""
	}
	
	MalterlibMemoryManager_CheckOverrideMemoryLeaks true
	{
		!!MalterlibMemoryManager_CheckOverrideMemoryLeaks ""
	}

	MalterlibThread_LinuxUseStaticThreadLocal true
	{
		!!MalterlibThread_LinuxUseStaticThreadLocal ""
	}

	Malterlib_AssumeMalterlibHost true
	{
		!!Malterlib_AssumeMalterlibHost ""
	}

	MalterlibModules "BuildAutomation;Tool;@(Property.MalterlibModules)"
}


// Import all roots
Import "Malterlib/Core/Malterlib.MHeader"
