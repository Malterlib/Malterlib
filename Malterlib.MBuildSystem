Import "Malterlib/Core/Malterlib.MHeader"

Property
{
	ProductCompanyUniqueIdentifier "org.malterlib"
	ProductCompany "Malterlib"
	{
		!!ProductCompany undefined
	}

	MalterlibMainMalterlibRepo true

	MalterlibEnableInternalTests true
	{
		!!MalterlibEnableInternalTests undefined
	}

	MalterlibEnableInternalWorkspaces true
	{
		!!MalterlibEnableInternalWorkspaces undefined
	}

	MalterlibTestsMem_EnablePerfTests true

	MalterlibMemoryManager_CheckOverrideMemoryLeaks true
	{
		!!MalterlibMemoryManager_CheckOverrideMemoryLeaks undefined
	}

	MalterlibThread_LinuxUseStaticThreadLocal true
	{
		!!MalterlibThread_LinuxUseStaticThreadLocal undefined
	}

	Malterlib_AssumeMalterlibHost true
	{
		!!Malterlib_AssumeMalterlibHost undefined
	}

	MalterlibEnableOptonalModules true

	MalterlibEnableThirdPartyComparisonTests true
	{
		!!MalterlibEnableThirdPartyComparisonTests undefined
	}

	MalterlibVerboseCMakeHash: bool = false
}

Import.CMake_VerboseHash true
{
	!!MalterlibVerboseCMakeHash true
}

Repository
{
	!!Repository.Type "Root"

	License MalterlibRepoDefaultLicenseConfig
	{
		!!Repository.License undefined
	}

	CheckLicense true
	{
		!!Repository.CheckLicense undefined
	}

	License #<CommentStyles> =+ {
		Path: ["count-lines"]
		, LinePrefix: "# "
		, DetectShebang: true
	}

	License #<CommentStyles> =+ {
		Path: ["mib"]
		, LinePrefix: "# "
		, DetectShebang: true
	}

	MalterlibRepoReusePaths =+ [
		".claude/*.json"
		, ".vscode/*.json"
		, ".ignore"
		, ".rgignore"
		, "Malterlib.sublime-project"
	]
}
